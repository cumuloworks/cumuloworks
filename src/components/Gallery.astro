---
import { Image } from 'astro:assets';
import { generateGallerySequence } from '@/utils/generateGallerySequence';

interface Props {
    folderPath: string;
}

const { folderPath } = Astro.props;

type ImageMetadata = import('astro').ImageMetadata;

function getImagesFromFolder(folder: string) {
    const images = import.meta.glob<ImageMetadata>('/src/**/*.{png,jpg,jpeg,gif,webp,PNG,JPG,JPEG,GIF,WEBP}', {
        eager: true,
        import: 'default',
    });
    return Object.entries(images)
        .filter(([path]) => path.startsWith(folder) && !/thumb\.(jpg|jpeg|png|gif|webp)$/i.test(path))
        .sort(([a], [b]) => a.localeCompare(b, undefined, { numeric: true }))
        .map(([, mod]) => mod);
}

const galleryImages = getImagesFromFolder(folderPath);
const uid = folderPath.replace(/[^a-z0-9]+/gi, '-').replace(/^-|-$/g, '');

const prepared = galleryImages.map((src, i) => ({
    src,
    alt: src.src.split('/').pop()?.split('.')[0] || `image-${i}`,
    id: `${uid}-${i}`,
}));

// Randomised row sequence (portrait-aware), ported from kumo.productions.
const firstAR = prepared[0] ? prepared[0].src.width / prepared[0].src.height : 1;
const sequence =
    prepared.length > 0
        ? firstAR < 1
            ? generateGallerySequence(prepared.length, 3, 5)
            : generateGallerySequence(prepared.length)
        : [];

let cursor = 0;
const rows = sequence
    .map((count) => {
        const imgs = prepared.slice(cursor, cursor + count);
        cursor += count;
        const ar = imgs[0] ? imgs[0].src.width / imgs[0].src.height : 1;
        return { ar, imgs };
    })
    .filter((r) => r.imgs.length > 0);

const ICON_PREV =
    '<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M15 18l-6-6 6-6"/></svg>';
const ICON_NEXT =
    '<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M9 18l6-6-6-6"/></svg>';
const ICON_CLOSE =
    '<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M18 6 6 18M6 6l12 12"/></svg>';
---

{
    prepared.length > 0 && (
        <div class="gallery" data-gallery={uid}>
            {rows.map((row) => (
                <div class="gallery-row">
                    {row.imgs.map((image, i) => (
                        <button
                            type="button"
                            class="gallery-cell"
                            style={`aspect-ratio:${row.ar}`}
                            data-index={prepared.indexOf(image)}
                            aria-label={`Open image ${i + 1}`}
                        >
                            <Image
                                src={image.src}
                                alt={image.alt}
                                width={Math.min(image.src.width, 1600)}
                                height={Math.round(Math.min(image.src.width, 1600) / (image.src.width / image.src.height))}
                                loading="lazy"
                            />
                        </button>
                    ))}
                </div>
            ))}

            <dialog class="lightbox" aria-label="Image viewer">
                <button type="button" class="lb-close" data-lb-close aria-label="Close" set:html={ICON_CLOSE} />
                <button type="button" class="lb-nav lb-prev" data-lb-nav="-1" aria-label="Previous" set:html={ICON_PREV} />
                <div class="lb-stage" />
                <button type="button" class="lb-nav lb-next" data-lb-nav="1" aria-label="Next" set:html={ICON_NEXT} />
            </dialog>
        </div>
    )
}

<script>
    function initGalleries() {
        document.querySelectorAll<HTMLElement>('.gallery').forEach((gallery) => {
            if (gallery.dataset.wired) return;
            gallery.dataset.wired = '1';

            const dialog = gallery.querySelector<HTMLDialogElement>('.lightbox');
            const stage = gallery.querySelector<HTMLElement>('.lb-stage');
            const cells = [...gallery.querySelectorAll<HTMLButtonElement>('.gallery-cell')];
            if (!dialog || !stage) return;
            let current = 0;

            // <dialog> is iOS Safari 15.4+; degrade gracefully on older browsers.
            const openDialog = () =>
                dialog.showModal ? dialog.showModal() : dialog.setAttribute('open', '');
            const closeDialog = () => (dialog.close ? dialog.close() : dialog.removeAttribute('open'));

            function show(index: number) {
                current = (index + cells.length) % cells.length;
                const img = cells[current].querySelector('img');
                stage.innerHTML = '';
                if (img) {
                    const clone = img.cloneNode(true) as HTMLImageElement;
                    clone.removeAttribute('loading');
                    clone.removeAttribute('class');
                    clone.removeAttribute('style');
                    stage.appendChild(clone);
                }
            }

            cells.forEach((cell, i) =>
                cell.addEventListener('click', () => {
                    show(i);
                    openDialog();
                })
            );
            gallery.querySelectorAll<HTMLButtonElement>('[data-lb-nav]').forEach((btn) =>
                btn.addEventListener('click', (e) => {
                    e.stopPropagation();
                    show(current + Number(btn.dataset.lbNav));
                })
            );
            gallery
                .querySelector('[data-lb-close]')
                ?.addEventListener('click', (e) => {
                    e.stopPropagation();
                    closeDialog();
                });
            // backdrop click (clicking the dialog itself, not the image) closes
            dialog.addEventListener('click', (e) => {
                if (e.target === dialog || e.target === stage) closeDialog();
            });
            dialog.addEventListener('keydown', (e) => {
                if (e.key === 'ArrowLeft') show(current - 1);
                if (e.key === 'ArrowRight') show(current + 1);
            });
        });
    }

    initGalleries();
    document.addEventListener('astro:after-swap', initGalleries);
</script>
